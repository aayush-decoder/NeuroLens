{
    "manifest_version": 3,
    "name": "Adaptive Reader",
    "version": "1.0",
    "description": "Distraction-free adaptive reading",
    "permissions": [
        "storage",
        "activeTab",
        "scripting"
    ],
    "host_permissions": [
        "<all_urls>",
        "https://aleta-stairless-nguyet.ngrok-free.dev/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_popup": "popup.html",
        "default_icon": "icons/icon128.png"
    },
    "web_accessible_resources": [
        {
            "resources": ["content/revision.md"],
            "matches": ["<all_urls>"]
        }
    ],
    "content_security_policy": {
        "extension_pages": "script-src 'self'; object-src 'self'"
    }
}
